# J's Room AI — Environment Variables Template
# Copy this to .env and fill in your keys

# Gemini API (Live API + Image Gen)
NEXT_PUBLIC_GEMINI_API_KEY=

# SerpAPI (Google Shopping product search)
SERPAPI_KEY=

# Unsplash API (Reference images)
UNSPLASH_APP_ID=
UNSPLASH_ACCESS_KEY=
UNSPLASH_SECRET_KEY=

# Google Cloud
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=
